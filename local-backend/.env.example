# ============================================================
# KH Builds — Configurazione
# Copia questo file in ".env" e compila i valori
# ============================================================

# --- Turso (produzione) -------------------------------------
# Ottieni da: turso db show <nome-db> --url
# e:          turso db tokens create <nome-db>
TURSO_DATABASE_URL=libsql://nome-db-tua-org.turso.io
TURSO_AUTH_TOKEN=il_tuo_token_qui

# --- Dev locale (SQLite) ------------------------------------
# Lascia le variabili Turso vuote per usare SQLite locale.
# Il DB verrà creato in local-backend/kh_builds.db automaticamente.

# --- Server -------------------------------------------------
PORT=3000
