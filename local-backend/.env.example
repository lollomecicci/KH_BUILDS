# ============================================================
# KH Builds — Configurazione
# Copia questo file in ".env" e compila i valori
# ============================================================

# --- Turso (produzione) -------------------------------------
# Ottieni da: turso db show <nome-db> --url
# e:          turso db tokens create <nome-db>
TURSO_DATABASE_URL=libsql://nome-db-tua-org.turso.io
TURSO_AUTH_TOKEN=il_tuo_token_qui

# --- Dev locale (SQLite) ------------------------------------
# Lascia le variabili Turso vuote per usare SQLite locale.
# Il DB verrà creato in local-backend/kh_builds.db automaticamente.

# --- Server -------------------------------------------------
PORT=3000

# --- Admin --------------------------------------------------
# Token segreto per approvare/rifiutare item via PATCH /api/admin/items/:type/:id/status
# Genera con: openssl rand -hex 32
ADMIN_TOKEN=cambia_questo_token_segreto

# --- OAuth --------------------------------------------------
# URL dell'app (senza slash finale)
APP_URL=http://localhost:3000

# Segreto per firmare i JWT — genera con: openssl rand -hex 32
JWT_SECRET=cambia_questo_segreto_jwt

# Discord OAuth — https://discord.com/developers/applications
# Redirect URI da impostare: APP_URL/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/
# Redirect URI da impostare: APP_URL/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI Screenshot Parsing ----------------------------------------
# Gemini free tier: https://aistudio.google.com/apikey (1500 req/day gratis)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
